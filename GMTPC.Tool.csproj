<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>GMTPC.Tool</RootNamespace>
    <AssemblyName>GMTPC.Tool</AssemblyName>
    <ApplicationIcon>idm 3.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>AnyCPU;x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <Deterministic>true</Deterministic>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <!-- Generate Build Number file before build -->
  <Target Name="GenerateBuildNumber" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <BuildNumber>$([System.DateTime]::Now.ToString(yyyy-MM-dd-HH-mm-ss))</BuildNumber>
    </PropertyGroup>
    <Exec Command="echo // Auto-generated build number&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo namespace GMTPC.Tool&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo {&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo     public static class BuildInfo&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo     {&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo         public const string BUILD_NUMBER = &quot;$(BuildNumber)&quot;;&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo     }&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot; &amp;&amp; echo }&gt;&gt; &quot;$(ProjectDir)Generated\BuildNumber.cs&quot;" />
  </Target>

  <ItemGroup>
    <Reference Include="System.Management" />
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="ExtractorApp\**" />
    <EmbeddedResource Remove="ExtractorApp\**" />
    <None Remove="ExtractorApp\**" />
    <Page Remove="ExtractorApp\**" />
  </ItemGroup>

  <ItemGroup>
    <None Update="App.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HtmlAgilityPack" Version="1.12.4" />
  </ItemGroup>

</Project>
